DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Vercel's Supabase integration may provide POSTGRES_URL instead.
POSTGRES_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

OURA_CLIENT_ID=YOUR_OURA_CLIENT_ID
OURA_CLIENT_SECRET=YOUR_OURA_CLIENT_SECRET
OURA_REDIRECT_URI=https://your-vercel-app.vercel.app/api/oura/oauth/callback
OURA_WEBHOOK_URL=https://your-vercel-app.vercel.app/api/oura/webhook
OURA_WEBHOOK_VERIFICATION_TOKEN=replace-with-random-secret

OURA_SCOPES="daily workout spo2 stress"
OURA_ENABLED_SOURCES=oura.daily_activity,oura.daily_readiness,oura.daily_sleep,oura.sleep,oura.daily_spo2,oura.daily_stress,oura.workout
OURA_BACKFILL_DAYS=90
OURA_WEBHOOK_DATA_TYPES=daily_activity,daily_readiness,daily_sleep,sleep,daily_spo2,daily_stress,workout
